# Application
PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# OpenRouter (ZDR-compliant AI)
OPENROUTER_API_KEY=your-openrouter-api-key
